# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=property_visual_explorer_dev
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — REQUIRED. The server refuses to start if this is missing (see
# src/config/jwtSecret.js) instead of silently falling back to a hardcoded
# string — that fallback used to be committed right here in this repo,
# which made every token forgeable by anyone who'd seen the source.
# Generate a long random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=

# Redis (for BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI (used by vocallmWorker.js for automated WhatsApp reply drafting)
OPENAI_API_KEY=your_openai_api_key

# WhatsApp BSP
BSP_GATEWAY_URL=https://your-bsp-provider.com/api/send
BSP_API_KEY=your_bsp_api_key

# Shared secret for verifying inbound webhook signatures from your BSP
# (leave unset in dev — signature check is skipped if this isn't configured)
WHATSAPP_WEBHOOK_SECRET=

# Shared WhatsApp number (E.164, e.g. 919999999999 — no '+') used for the
# free V4 "chat with us" wa.me link on tenants without their own dedicated
# number (Ch.12.3 of the Multi-tenancy doc)
WHATSAPP_SHARED_NUMBER=919999999999

# App
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins in production
# (e.g. https://app.yourdomain.com). Leave blank in local dev.
CORS_ORIGIN=

# ── Phase 7: Email (SMTP) ──────────────────────────────────────────
# Works with any SMTP provider (Gmail app password, SendGrid, Postmark,
# Amazon SES SMTP, etc.). Leave SMTP_HOST blank in dev — onboarding/receipt
# emails will be skipped and logged to console instead of failing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Wayne AI <no-reply@wayneesolutions.com>

# ── Phase 7: Billing (Stripe) ──────────────────────────────────────
# Switched from Razorpay to Stripe after the initial Phase 7 build — this
# section previously still listed the old Razorpay vars even though the
# code no longer used them. From your Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
# From Stripe dashboard → Developers → Webhooks (separate secret from the
# API key above — set when creating the webhook endpoint pointing at
# POST /api/v1/webhooks/stripe, subscribed to at least: checkout.session.completed,
# invoice.paid, customer.subscription.deleted). Leave blank in dev to skip
# verification.
STRIPE_WEBHOOK_SECRET=

# ── WhatsApp: Meta Cloud API tenant routing ────────────────────────
# If using Meta's WhatsApp Cloud API (as opposed to a BSP that sends a raw
# "to" number), each tenant's dedicated WhatsApp number has an opaque
# phone_number_id from Meta — store it on that tenant's row
# (tenants.phone_number_id) so inbound webhook messages route to the
# correct tenant. No single env var here; this is per-tenant data.
