# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=property_visual_explorer_dev
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_before_deploying

# Redis (for BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OpenAI (used by vocallmWorker.js for automated WhatsApp reply drafting)
OPENAI_API_KEY=your_openai_api_key

# WhatsApp BSP
BSP_GATEWAY_URL=https://your-bsp-provider.com/api/send
BSP_API_KEY=your_bsp_api_key

# Shared secret for verifying inbound webhook signatures from your BSP
# (leave unset in dev — signature check is skipped if this isn't configured)
WHATSAPP_WEBHOOK_SECRET=

# Shared WhatsApp number (E.164, e.g. 919999999999 — no '+') used for the
# free V4 "chat with us" wa.me link on tenants without their own dedicated
# number (Ch.12.3 of the Multi-tenancy doc)
WHATSAPP_SHARED_NUMBER=919999999999

# App
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins in production
# (e.g. https://app.yourdomain.com). Leave blank in local dev.
CORS_ORIGIN=
