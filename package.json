{
  "name": "property-visual-explorer-api",
  "version": "1.0.0",
  "description": "Property Visual Explorer - WhatsApp Lead Engine for Punjab Real Estate",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "setup": "npm run migrate && npm run seed",
    "worker:geo": "node src/workers/geoEnrichmentWorker.js",
    "worker:landmark": "node src/workers/landmarkWorker.js",
    "worker:vocallm": "node src/workers/vocallmWorker.js",
    "worker:whatsapp": "node src/workers/whatsappOutboundWorker.js",
    "workers": "concurrently \"npm:worker:geo\" \"npm:worker:landmark\" \"npm:worker:vocallm\" \"npm:worker:whatsapp\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.5",
    "stripe": "^22.3.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
